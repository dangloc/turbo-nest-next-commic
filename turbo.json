{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "WP_MYSQL_HOST",
    "WP_MYSQL_PORT",
    "WP_MYSQL_USER",
    "WP_MYSQL_PASSWORD",
    "WP_MYSQL_DATABASE",
    "ETL_CHAPTER_CHUNK_SIZE",
    "ETL_QUARANTINE_PATH"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "etl:migrate": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": false,
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": []
    }
  }
}
