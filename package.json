{
  "name": "next-nest-turbo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "build:api": "turbo run build --filter=api",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "lint": "turbo run lint",
    "lint:web": "turbo run lint --filter=web",
    "lint:api": "turbo run lint --filter=api",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "check-types:web": "turbo run check-types --filter=web",
    "check-types:api": "turbo run check-types --filter=api",
    "etl:migrate": "turbo run etl:migrate --filter=api --cache=local:r,remote:r",
    "guard:prisma-migrations": "node scripts/prisma-migration-guard.mjs --base=origin/main"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.3",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "zod": "^4.3.6"
  }
}
